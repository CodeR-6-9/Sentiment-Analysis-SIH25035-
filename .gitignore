/frontend/Dashboard/build/
/frontend/Dashboard/dist/
/frontend/Dashboard/.npm
/frontend/Dashboard/npm-debug.log*
/frontend/Dashboard/yarn-error.log*

# Frontend Secrets
/frontend/Dashboard/.env
/frontend/Dashboard/.env.local
/frontend/Dashboard/.env.development
/frontend/Dashboard/.env.test
/frontend/Dashboard/.env.production


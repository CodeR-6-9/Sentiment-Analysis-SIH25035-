# =========================
# Backend (Python / Flask)
# =========================
/backend/.venv/
/backend/__pycache__/
/backend/*.py[cod]
/backend/*$py.class

# Logs and Databases
/backend/*.log
/backend/*.db
/backend/*.sqlite3

# Backend Secrets
/backend/.env

# =========================
# Frontend (React / Node.js)
# =========================
